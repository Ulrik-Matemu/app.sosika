rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match for the vendors collection
    match /vendors/{vendorId} {
      // Anyone can view vendor listings
      allow read: if true;
      // Only the vendor owner themselves can write/modify their listing
      allow write: if request.auth != null && request.auth.uid == vendorId;
    }

    // Match for the menuItems collection 
    match /menuItems/{itemId} {
      // Anyone can read menu items
      allow read: if true;
      // Only the owner vendor can write/update/delete their menu items
      allow create: if request.auth != null && request.resource.data.vendor_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.vendor_id == request.auth.uid;
    }

    // Match for the reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Authenticated users can write reviews
      allow write: if request.auth != null;
    }

    // Match for the orders collection
    match /orders/{orderId} {
      // Anyone (including guests) can submit orders
      allow create: if true;
      // Only vendors associated with the order or the customer themselves can read/update
      allow read, update: if request.auth != null && (
        request.auth.uid in resource.data.vendor_ids || 
        request.auth.uid == resource.data.userId
      );
      // Allow getting a single order (e.g. for guest tracking) but restrict listing
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid in resource.data.vendor_ids;
    }
    
  }
}